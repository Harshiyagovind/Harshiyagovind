from collections import deque, defaultdict
from typing import List

class Solution:
    def numBusesToDestination(self, routes: List[List[int]], source: int, target: int) -> int:
        if source == target:
            return 0

        # 1. Map each stop to the list of bus routes that pass through it
        stop_to_routes = defaultdict(list)
        for route_id, stops in enumerate(routes):
            for stop in stops:
                stop_to_routes[stop].append(route_id)

        # 2. BFS initialization
        # Queue stores (route_id, number_of_buses_taken)
        queue = deque()
        visited_routes = set()
        visited_stops = {source}

        # Add all routes passing through the starting stop
        for route_id in stop_to_routes[source]:
            visited_routes.add(route_id)
            queue.append((route_id, 1))

        # 3. BFS across routes
        while queue:
            route_id, buses = queue.popleft()

            # Check all stops in the current bus route
            for stop in routes[route_id]:
                if stop == target:
                    return buses
                
                # If we haven't visited this stop, check its other connecting routes
                if stop not in visited_stops:
                    visited_stops.add(stop)
                    for next_route in stop_to_routes[stop]:
                        if next_route not in visited_routes:
                            visited_routes.add(next_route)
                            queue.append((next_route, buses + 1))
                            
        return -1
